@import "tailwindcss";
@import "tw-animate-css";

@custom-variant dark (&:is(.dark *));

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);

  --font-sans: var(--font-heading), var(--font-body);
  --font-mono: var(--font-geist-mono);

  --color-sidebar-ring: var(--sidebar-ring);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar: var(--sidebar);

  --color-chart-5: var(--chart-5);
  --color-chart-4: var(--chart-4);
  --color-chart-3: var(--chart-3);
  --color-chart-2: var(--chart-2);
  --color-chart-1: var(--chart-1);

  --color-ring: var(--ring);
  --color-input: var(--input);
  --color-border: var(--border);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-accent-foreground: var(--accent-foreground);
  --color-accent: var(--accent);
  --color-muted-foreground: var(--muted-foreground);
  --color-muted: var(--muted);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-secondary: var(--secondary);
  --color-primary-foreground: var(--primary-foreground);
  --color-primary: var(--primary);
  --color-popover-foreground: var(--popover-foreground);
  --color-popover: var(--popover);
  --color-card-foreground: var(--card-foreground);
  --color-card: var(--card);

  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);

  /* Custom Brand Colors */
  --color-brand-green: var(--brand-green);
  --color-brand-green-light: var(--brand-green-light);
  --color-brand-green-dark: var(--brand-green-dark);
  --color-brand-gold: var(--brand-gold);
  --color-brand-gold-light: var(--brand-gold-light);
  --color-brand-gold-dark: var(--brand-gold-dark);
  --color-brand-teal: var(--brand-teal);
  --color-brand-cream: var(--brand-cream);
  --color-text-dark: var(--text-dark);
  --color-text-light: var(--text-light);
  --color-text-muted: var(--text-muted);
  --color-success: var(--success);
  --color-success-foreground: var(--success-foreground);
  --color-warning: var(--warning);
  --color-warning-foreground: var(--warning-foreground);
  --color-info: var(--info);
  --color-info-foreground: var(--info-foreground);
}

:root {
  /* ================================================
     ALPHAFUNDING - BRITISH RACING GREEN + GOLD THEME
     All colors with hex codes for full contrast
     ================================================ */

  /* Fonts */
  --font-heading: "Montserrat", "Open Sans", Arial, sans-serif;
  --font-body: "Open Sans", "Roboto", Arial, sans-serif;

  /* Radius */
  --radius: 0.5rem;

  /* ===================
     CORE BRAND COLORS
     =================== */

  /* British Racing Green Palette */
  --brand-green: #14532D;
  /* Primary green */
  --brand-green-light: #166534;
  /* Lighter green for hovers */
  --brand-green-dark: #0F3D22;
  /* Darker green for depth */

  /* Gold Palette */
  --brand-gold: #D4A418;
  /* Primary gold - CTAs */
  --brand-gold-light: #EAB308;
  /* Brighter gold for hovers */
  --brand-gold-dark: #A16207;
  /* Darker gold for pressed states */

  /* Supporting Colors */
  --brand-teal: #0D9488;
  /* Accent teal */
  --brand-cream: #FEFCE8;
  /* Warm cream for highlights */

  /* ===================
     SEMANTIC TEXT COLORS
     =================== */
  --text-dark: #1C1917;
  /* Primary body text on light bg */
  --text-light: #FFFFFF;
  /* Text on dark backgrounds */
  --text-muted: #57534E;
  /* Secondary/muted text */

  /* ===================
     LIGHT MODE (DEFAULT)
     =================== */

  /* Page Background & Text */
  --background: #FFFFFF;
  /* White page background */
  --foreground: #1C1917;
  /* Charcoal body text - HIGH CONTRAST */

  /* Cards */
  --card: #F5F5F4;
  /* Warm gray card background */
  --card-foreground: #14532D;
  /* Green card titles - CONTRAST ON GRAY */

  /* Popovers/Dropdowns */
  --popover: #FFFFFF;
  /* White popover bg */
  --popover-foreground: #1C1917;
  /* Dark text - HIGH CONTRAST */

  /* Primary (Navigation, Headers, Key Elements) */
  --primary: #14532D;
  /* British Racing Green */
  --primary-foreground: #FFFFFF;
  /* White text on green - HIGH CONTRAST */

  /* Secondary (Main CTAs, Buttons) */
  --secondary: #D4A418;
  /* Rich Gold */
  --secondary-foreground: #0F3D22;
  /* Dark green text on gold - HIGH CONTRAST */

  /* Accent (Success states, Secondary CTAs) */
  --accent: #0D9488;
  /* Warm Teal */
  --accent-foreground: #FFFFFF;
  /* White text on teal - HIGH CONTRAST */

  /* Muted (Subtle backgrounds, disabled states) */
  --muted: #F5F5F4;
  /* Light warm gray */
  --muted-foreground: #57534E;
  /* Stone gray text - READABLE ON LIGHT */

  /* Destructive (Errors, Warnings) */
  --destructive: #DC2626;
  /* Red for errors */
  --destructive-foreground: #FFFFFF;
  /* White text on red */

  /* Success State */
  --success: #16A34A;
  /* Green success */
  --success-foreground: #FFFFFF;
  /* White text */

  /* Warning State */
  --warning: #EA580C;
  /* Orange warning */
  --warning-foreground: #FFFFFF;
  /* White text */

  /* Info State */
  --info: #0284C7;
  /* Blue info */
  --info-foreground: #FFFFFF;
  /* White text */

  /* Borders & Inputs */
  --border: #D6D3D1;
  /* Stone border - visible on white */
  --input: #FFFFFF;
  /* White input background */
  --ring: #D4A418;
  /* Gold focus ring */

  /* ===================
     CHART COLORS
     =================== */
  --chart-1: #14532D;
  /* Green */
  --chart-2: #D4A418;
  /* Gold */
  --chart-3: #0D9488;
  /* Teal */
  --chart-4: #166534;
  /* Light Green */
  --chart-5: #A16207;
  /* Dark Gold */

  /* ===================
     SIDEBAR
     =================== */
  --sidebar: #14532D;
  /* Green sidebar */
  --sidebar-foreground: #FFFFFF;
  /* White text - HIGH CONTRAST */
  --sidebar-primary: #D4A418;
  /* Gold highlights */
  --sidebar-primary-foreground: #0F3D22;
  /* Dark text on gold */
  --sidebar-accent: #166534;
  /* Lighter green for hover */
  --sidebar-accent-foreground: #FFFFFF;
  /* White text */
  --sidebar-border: #166534;
  /* Subtle green border */
  --sidebar-ring: #D4A418;
  /* Gold focus ring */

  /* ===================
     GRADIENT DEFINITIONS
     For gradient text effects
     =================== */

  /* Gradient 1: Gold to Amber (Premium Feel) */
  --gradient-gold: linear-gradient(135deg, #D4A418 0%, #F59E0B 50%, #EAB308 100%);

  /* Gradient 2: Green to Teal (Trust/Growth) */
  --gradient-green: linear-gradient(135deg, #14532D 0%, #166534 50%, #0D9488 100%);

  /* Gradient 3: Gold to Green (Brand Fusion) */
  --gradient-brand: linear-gradient(135deg, #D4A418 0%, #16A34A 50%, #14532D 100%);
}

/* ===================
   DARK MODE
   =================== */
.dark {
  /* Page Background & Text */
  --background: #0F3D22;
  /* Dark green background */
  --foreground: #F5F5F4;
  /* Light text - HIGH CONTRAST */

  /* Cards */
  --card: #14532D;
  /* Green card background */
  --card-foreground: #FFFFFF;
  /* White text - HIGH CONTRAST */

  /* Popovers/Dropdowns */
  --popover: #14532D;
  /* Green popover bg */
  --popover-foreground: #FFFFFF;
  /* White text - HIGH CONTRAST */

  /* Primary */
  --primary: #D4A418;
  /* Gold becomes primary in dark mode */
  --primary-foreground: #0F3D22;
  /* Dark green text on gold */

  /* Secondary */
  --secondary: #166534;
  /* Lighter green */
  --secondary-foreground: #FFFFFF;
  /* White text */

  /* Accent */
  --accent: #0D9488;
  /* Teal stays */
  --accent-foreground: #FFFFFF;
  /* White text */

  /* Muted */
  --muted: #14532D;
  /* Dark green muted */
  --muted-foreground: #D6D3D1;
  /* Light stone text - READABLE */

  /* Destructive */
  --destructive: #EF4444;
  /* Brighter red for dark mode */
  --destructive-foreground: #FFFFFF;

  /* Success */
  --success: #22C55E;
  /* Brighter green */
  --success-foreground: #0F3D22;
  /* Dark text */

  /* Warning */
  --warning: #F97316;
  /* Brighter orange */
  --warning-foreground: #0F3D22;
  /* Dark text */

  /* Info */
  --info: #38BDF8;
  /* Brighter blue */
  --info-foreground: #0F3D22;
  /* Dark text */

  /* Borders & Inputs */
  --border: #166534;
  /* Visible green border */
  --input: #14532D;
  /* Green input bg */
  --ring: #D4A418;
  /* Gold focus ring */

  /* Charts */
  --chart-1: #D4A418;
  /* Gold */
  --chart-2: #22C55E;
  /* Bright green */
  --chart-3: #14B8A6;
  /* Bright teal */
  --chart-4: #FBBF24;
  /* Amber */
  --chart-5: #F5F5F4;
  /* Light */

  /* Sidebar */
  --sidebar: #0F3D22;
  /* Darker green */
  --sidebar-foreground: #F5F5F4;
  /* Light text */
  --sidebar-primary: #D4A418;
  /* Gold */
  --sidebar-primary-foreground: #0F3D22;
  --sidebar-accent: #166534;
  /* Lighter green hover */
  --sidebar-accent-foreground: #FFFFFF;
  --sidebar-border: #14532D;
  --sidebar-ring: #D4A418;

  /* Dark mode gradients (brighter for visibility) */
  --gradient-gold: linear-gradient(135deg, #EAB308 0%, #FBBF24 50%, #FCD34D 100%);
  --gradient-green: linear-gradient(135deg, #22C55E 0%, #14B8A6 50%, #0D9488 100%);
  --gradient-brand: linear-gradient(135deg, #EAB308 0%, #22C55E 50%, #14B8A6 100%);
}

/* ===================
   NAVIGATION SHADOW
   =================== */
.nav-shadow {
  box-shadow: 0 4px 25px 0 rgb(0 0 0 / 0.15);
}

/* ===================
   BASE STYLES
   =================== */
@layer base {
  * {
    @apply border-border outline-ring/50;
  }

  html {
    font-family: var(--font-body);
  }

  body {
    @apply bg-background text-foreground;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: var(--font-heading);
  }
}

/* ===================
   GRADIENT TEXT CLASSES
   Use these for headlines and feature text
   =================== */

/* Gradient 1: Gold Premium - Best for hero headlines, CTAs */
.text-gradient-gold {
  background: var(--gradient-gold);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Gradient 2: Green Trust - Best for "About Us", trust signals */
.text-gradient-green {
  background: var(--gradient-green);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Gradient 3: Brand Fusion - Best for special sections, features */
.text-gradient-brand {
  background: var(--gradient-brand);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ===================
   GRADIENT BACKGROUNDS
   For sections and cards
   =================== */

/* Hero gradient - dark green to lighter green */
.bg-gradient-hero {
  background: linear-gradient(135deg, #0F3D22 0%, #14532D 50%, #166534 100%);
}

/* CTA section gradient - gold tones */
.bg-gradient-cta {
  background: linear-gradient(135deg, #A16207 0%, #D4A418 50%, #EAB308 100%);
}

/* Feature section - subtle green */
.bg-gradient-feature {
  background: linear-gradient(180deg, #F5F5F4 0%, #ECFDF5 100%);
}

/* ===================
   UTILITY CLASSES
   =================== */

/* Gold button hover effect */
.btn-gold {
  @apply bg-secondary text-secondary-foreground;
  transition: all 0.2s ease;
}

.btn-gold:hover {
  background-color: #EAB308;
  box-shadow: 0 4px 14px 0 rgba(212, 164, 24, 0.4);
}

/* Green button hover effect */
.btn-green {
  @apply bg-primary text-primary-foreground;
  transition: all 0.2s ease;
}

.btn-green:hover {
  background-color: #166534;
  box-shadow: 0 4px 14px 0 rgba(20, 83, 45, 0.4);
}

/* Card hover lift effect */
.card-hover {
  transition: all 0.3s ease;
}

.card-hover:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(20, 83, 45, 0.15);
}

/* ===================
   ANIMATIONS
   =================== */
@keyframes slide-in {
  from {
    transform: translateX(-120%);
    opacity: 0;
  }

  to {
    transform: translateX(0);
    opacity: 1;
  }
}

.animate-slide-in {
  animation: slide-in 0.4s ease-out;
}

@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in-up {
  animation: fade-in-up 0.5s ease-out;
}

@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }

  100% {
    background-position: 200% 0;
  }
}

.animate-shimmer {
  background: linear-gradient(90deg,
      #D4A418 0%,
      #EAB308 25%,
      #FBBF24 50%,
      #EAB308 75%,
      #D4A418 100%);
  background-size: 200% 100%;
  animation: shimmer 3s infinite linear;
}