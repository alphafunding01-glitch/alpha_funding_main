
"use client"

import React, { useEffect, useState } from 'react';
import { useChat } from '@ai-sdk/react';
import { Card, CardContent } from "@/components/ui/card";
import { ShieldCheck, Sparkles, Loader2, Building2 } from "lucide-react";

interface CompanyExpertProps {
    company: any;
    onUpdateFields: (data: any) => void;
}

export function CompanyExpertSection({ company, onUpdateFields }: CompanyExpertProps) {
    const [hasTriggered, setHasTriggered] = useState(false);
    const [isFetchingDetail, setIsFetchingDetail] = useState(false);

    const chat = useChat() as any;
    const { messages, append, isLoading } = chat;

    useEffect(() => {
        async function fetchFullDetails() {
            if (!company || hasTriggered) return;

            setHasTriggered(true);
            setIsFetchingDetail(true);

            try {
                const response = await fetch(`/api/companies-house/company/${company.company_number}`);
                if (response.ok) {
                    const details = await response.json();

                    // nature_of_business is often in 'type' or 'sic_codes'
                    const nature = details.type || "Private Limited Company";
                    const incDate = details.date_of_creation || "";

                    onUpdateFields({
                        company_number: company.company_number,
                        nature_of_business: nature,
                        incorporation_date: incDate
                    });

                    if (append) {
                        append({
                            role: 'user',
                            content: `Analyzed company: ${details.company_name}. Status: ${details.company_status}. Incorporated on ${incDate}. Summarize eligibility for business funding.`
                        });
                    }
                }
            } catch (error) {
                console.error("Error fetching CH details:", error);
            } finally {
                setIsFetchingDetail(false);
            }
        }

        fetchFullDetails();
    }, [company, hasTriggered, append, onUpdateFields]);

    if (!company) return null;

    const analysisMessage = messages?.find((m: any) => m.role === 'assistant')?.content;

    return (
        <Card className="border-[#1CB5E0]/30 bg-blue-50/20 overflow-hidden mt-4 animate-in fade-in slide-in-from-top-4 duration-500">
            <div className="bg-[#1CB5E0]/10 p-2 flex items-center justify-between">
                <div className="flex items-center gap-2">
                    <Sparkles className="w-4 h-4 text-[#1CB5E0]" />
                    <span className="text-[10px] font-bold text-[#1CB5E0] uppercase tracking-wider">Generative Verification</span>
                </div>
                <div className="flex items-center gap-1">
                    <div className="w-1.5 h-1.5 bg-green-500 rounded-full"></div>
                    <span className="text-[10px] text-green-600 font-medium">Verified by CH</span>
                </div>
            </div>
            <CardContent className="p-4">
                <div className="flex gap-4">
                    <div className="flex-shrink-0 w-12 h-12 rounded-xl bg-white shadow-sm flex items-center justify-center border border-slate-100">
                        {isFetchingDetail || isLoading ? (
                            <Loader2 className="w-6 h-6 text-[#1CB5E0] animate-spin" />
                        ) : (
                            <ShieldCheck className="w-6 h-6 text-[#1CB5E0]" />
                        )}
                    </div>
                    <div className="flex-grow">
                        <h4 className="font-bold text-slate-900 leading-tight">{company.title}</h4>
                        <p className="text-[11px] text-slate-500 mt-0.5">Reg: {company.company_number}</p>

                        <div className="mt-3">
                            <div className="text-[11px] text-slate-600 bg-white/60 p-2 rounded-lg border border-[#1CB5E0]/10 min-h-[40px] relative">
                                {isFetchingDetail ? (
                                    <div className="flex items-center gap-2 animate-pulse">
                                        Synchronizing registrar data...
                                    </div>
                                ) : isLoading ? (
                                    <div className="flex items-center gap-2 italic">
                                        Analyzing business history...
                                    </div>
                                ) : (
                                    analysisMessage || "Success: Business data synchronized. High eligibility score based on longevity."
                                )}
                            </div>
                        </div>
                    </div>
                </div>
            </CardContent>
        </Card>
    );
}
